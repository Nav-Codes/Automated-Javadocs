{
  "publisher": "NavjotKehal",
  "repository": "https://github.com/Nav-Codes/Automated-Javadocs",
  "name": "automated-javadocs",
  "displayName": "Automated Javadocs",
  "description": "Gone are the days of manually typing Javadoc comments for your methods! Automated Javadocs is a VSCode plugin that automates the process of writing Javadoc comments. Just run 'Automated Javadocs: Inject Javadocs' in the Command Palette, and watch the magic unfold!",
  "version": "0.0.67",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "automated-javadocs.injectJavadocs",
        "title": "Automated Javadocs: Inject Javadocs"
      }
    ],
    "configuration": {
      "title": "Automated Javadocs",
      "properties": {
        "automated-javadocs.model": {
          "type": "string",
          "default": "gpt-4.1-mini",
          "description": "OpenAI model to use for method descriptions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
